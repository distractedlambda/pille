#lang rhombus/static

import:
  ffi open
  pille/hosted open
  pille/spmd/embedded open

check:
  let len = 57
  let buf = new uint32_t[len]
  pille(buf :: PtrMut(UInt(32)), len :: NativeUInt):
    spmd(8):
      par_for (idx in 0..len):
        buf[idx] := 42
  for List (i in 0..len):
    mem buf[i]
  ~is:
    for List(i in 0..57):
      42
