#lang rhombus/static

import:
  ffi open
  pille/hosted open
  pille/spmd/embedded open

check:
  let len = 57
  let buf = new uint32_t[len]
  pille(buf :: PtrMut(UInt(32)), len :: NativeUInt):
    spmd(8):
      var idx :: Varying(NativeUInt) = program_index
      while (idx < len):
        buf[idx] := 42
        idx := idx + program_count
  for List (i in 0..len):
    mem buf[i]
  ~is:
    for List(i in 0..57):
      42
