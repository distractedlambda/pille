#lang rhombus/static

import:
  pille/hosted open

check:
  pille:
    5 ∈ 4..7
  ~is #true

check:
  pille:
    (5 :: Int(32)) ∈ 4..7
  ~is #true

check:
  pille:
    (5 :: Int(32)) ∈ 4..(7 :: Int(17))
  ~is #true

check:
  pille:
    (5 :: Int(32)) ∈ (4 :: Int(8)) .. (7 :: Int(17))
  ~is #true

check:
  pille:
    (5 :: Int(32)) ∈ (4 :: Int(8)) .. (5 :: Int(17))
  ~is #false

check:
  pille:
    (5 :: Int(32)) ∈ (4 :: Int(8)) <..= (5 :: Int(17))
  ~is #true

check:
  pille:
    (5 :: Int(32)) ∈ (5 :: Int(8)) <..= (5 :: Int(17))
  ~is #false

check:
  pille:
    var sum :: Int(32) = 0
    for (i ∈ 1..10):
      sum := sum + i
    sum
  ~is 45

check:
  pille:
    var sum :: Int(32) = 0
    for (i ∈ 1..=10):
      sum := sum + i
    sum
  ~is 55

check:
  pille:
    var sum :: Int(32) = 0
    for (i ∈ 1<..=10):
      sum := sum + i
    sum
  ~is 54
