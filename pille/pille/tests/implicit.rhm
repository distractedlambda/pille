#lang rhombus/static

import:
  pille/hosted open

pille.implicit scale :: Const(_ :: nat)

pille.fun apply_scale(lhs, using scale):
  lhs * scale

pille.fun apply_scale_twice(x, using scale):
  apply_scale(apply_scale(x))

pille.fun apply_scale_twice_transparent(x):
  ~transparent
  apply_scale(apply_scale(x))

check:
  pille:
    using scale = 2
    scale
  ~is 2

check:
  pille:
    using scale = 2
    apply_scale(4)
  ~is 8

check:
  pille:
    using scale = 2
    apply_scale_twice(4)
  ~is 16

check:
  pille:
    apply_scale_twice(4)
  ~throws "no matching method"

check:
  pille:
    using scale = 2
    apply_scale_twice_transparent(4)
  ~is 16
