           llvm.ConstantInt(builder.int_type(32), align),
           mask_val,
           passthru_val]))

//==============================================================================
export pille_expr.macro 'masked_scatter(
                           $(vals :: pille_expr_meta.Parsed),
                           $(ptrs :: pille_expr_meta.Parsed),
                           $(align :: const_expr_meta.Parsed),
                           $(mask :: pille_expr_meta.Parsed))':
  pille_expr_meta.pack_concretize(
    'concretize_masked_scatter(
       $(pille_expr_meta.unpack_concretize(vals)),
       $(pille_expr_meta.unpack_concretize(ptrs)),
       $(const_expr_meta.unpack_rhombus_expr(align)),
       $(pille_expr_meta.unpack_concretize(mask)))')

fun concretize_masked_scatter(vals :~ Expr, ptrs :~ Expr, align, mask :~ Expr):
  let vals_low = vals.lower_rvalue
  let ptrs_low = ptrs.lower_rvalue
  let mask_low = mask.lower_rvalue
  Expr.Rvalue(
    ~type: VoidType(),
    ~lower:
      fun(env):
        let builder = lowering.builder()
        let vals_val = vals_low(env)
        let ptrs_val = ptrs_low(env)
        let mask_val = mask_low(env)
        builder.create_intrinsic_call(
          "llvm.masked.scatter",
          [vals_val!!.type, ptrs_val!!.type],
          [vals_val,
           ptrs_val,
           llvm.ConstantInt(builder.int_type(32), align),
           mask_val])
        #false)
