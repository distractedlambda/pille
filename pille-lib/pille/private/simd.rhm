method (mask :: Simd(Boolean, n)).sparse_lt(lhs :: α, rhs :: β) :: SparseSimd(Boolean, n):
  ~where γ && SparseSimd(UInt(_) || RawPtr || PtrTo(_), n) = unify(α, β)
  let lhs = lhs :: γ
  let rhs = rhs :: γ
