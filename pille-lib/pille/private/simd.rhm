method (mask :: Simd(Boolean, n)).sparse_le(lhs :: α, rhs :: β) :: SparseSimd(Boolean, n):
  ~where γ && SparseSimd(Int(_), n) = unify(α, β)
  let lhs = lhs :: γ
  let rhs = rhs :: γ
  when ub.checked
  | check_mask_covers(mask, lhs)
    check_mask_covers(mask, rhs)
