  when ub.checked
  | check_mask_covers(mask, lhs)
    check_mask_covers(mask, rhs)
  γ{prim.xor(lhs.$sparse_data, rhs.$sparse_data),
    mask}

//==============================================================================
method (mask :: Simd(Boolean, n)).sparse_eq(lhs :: α, rhs :: β) :: SparseSimd(Boolean, n):
  ~where γ && SparseSimd(Bitwise || RawPtr || PtrTo(_), n) = unify(α, β)
  let lhs = lhs :: γ
  let rhs = rhs :: γ
  when ub.checked
  | check_mask_covers(mask, lhs)
    check_mask_covers(mask, rhs)
  SparseSimd(Boolean, n){prim.icmp_eq(lhs.$sparse_data, rhs.$sparse_data), mask}

method (mask :: Simd(Boolean, n)).sparse_ne(lhs :: α, rhs :: β) :: SparseSimd(Boolean, n):
  ~where γ && SparseSimd(Bitwise || RawPtr || PtrTo(_), n) = unify(α, β)
