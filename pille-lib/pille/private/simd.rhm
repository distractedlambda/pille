#lang pille/private/kernel

import:
  "cond.rhm" open
  "const_ops.rhm" open
  "generic_ops.rhm" open
  "int.rhm" open
  "panic.rhm" open
  "pointer.rhm" open
  "type_traits.rhm" open

//==============================================================================
coercion (elem :: σ) :: Simd(δ && CoercesFrom(σ), n):
  prim.splat(elem :: δ, n)

//==============================================================================
coercion (src :: Simd(UInt(ws), n)) :: δ && Simd(UInt(wd), n):
  ~when ws < wd
  prim.zext(src, ~to: δ)

coercion (src :: Simd(UInt(ws), n)) :: δ && Simd(Int(wd), n):
  ~when ws < wd
  prim.zext(src, ~to: δ)

coercion (src :: Simd(Int(ws), n)) :: δ && Simd(Int(wd), n):
  ~when ws < wd
  prim.sext(src, ~to: δ)

//==============================================================================
unify(Simd(α, n), β):
  Simd(unify(α, β), n)

unify(Simd(α, n), Simd(β, n)):
  Simd(unify(α, β), n)

//==============================================================================
property (const σ && Simd(UInt(w), n)).iota :: σ:
  ~when bit_length(n - 1) ≤ w
  prim.iota(σ)

property (const σ && Simd(Int(w), n)).iota :: σ:
  ~when bit_length(n - 1) < w
  prim.iota(σ)

//==============================================================================
method (rhs :: α && Simd(Bitwise, _)).$not() :: α:
  prim.not(rhs)

method (lhs :: α && Simd(Bitwise, _)).$and(rhs :: α) :: α:
  prim.and(lhs, rhs)

method (lhs :: α && Simd(Bitwise, _)).$or(rhs :: α) :: α:
  prim.or(lhs, rhs)

method (lhs :: α && Simd(Bitwise, _)).$xor(rhs :: α) :: α:
  prim.xor(lhs, rhs)

//==============================================================================
method (smd :: Simd(α && Bitwise, n)).reduce_and() :: α:
  prim.reduce_and(smd)

method (smd :: Simd(Boolean, n)).all() :: Boolean:
  smd.reduce_and()

method (smd :: Simd(α && Bitwise, n)).reduce_or() :: α:
  prim.reduce_or(smd)

method (smd :: Simd(Boolean, n)).any() :: Boolean:
  smd.reduce_or()

method (smd :: Simd(α && Bitwise, n)).reduce_xor() :: α:
  prim.reduce_xor(smd)

method (smd :: Simd(Boolean, n)).parity() :: Boolean:
  smd.reduce_xor()

//==============================================================================
method (lhs :: Simd(α, n)).$eq(rhs :: Simd(α, n)) :: Simd(Boolean, n):
  ~where Bitwise || RawPtr || PtrTo(_) = α
  prim.icmp_eq(lhs, rhs)

method (lhs :: Simd(α, n)).$ne(rhs :: Simd(α, n)) :: Simd(Boolean, n):
  ~where Bitwise || RawPtr || PtrTo(_) = α
  prim.icmp_ne(lhs, rhs)

method (lhs :: Simd(α, n)).$lt(rhs :: Simd(α, n)) :: Simd(Boolean, n):
  ~where UInt(_) || RawPtr || PtrTo(_) = α
  prim.icmp_ult(lhs, rhs)

method (lhs :: Simd(α, n)).$lt(rhs :: Simd(α, n)) :: Simd(Boolean, n):
  ~where Int(_) = α
  prim.icmp_slt(lhs, rhs)

method (lhs :: Simd(α, n)).$le(rhs :: Simd(α, n)) :: Simd(Boolean, n):
  ~where UInt(_) || RawPtr || PtrTo(_) = α
  prim.icmp_ule(lhs, rhs)

method (lhs :: Simd(α, n)).$le(rhs :: Simd(α, n)) :: Simd(Boolean, n):
  ~where Int(_) = α
  prim.icmp_sle(lhs, rhs)

method (lhs :: Simd(α, n)).$gt(rhs :: Simd(α, n)) :: Simd(Boolean, n):
  ~where UInt(_) || RawPtr || PtrTo(_) = α
  prim.icmp_ugt(lhs, rhs)

method (lhs :: Simd(α, n)).$gt(rhs :: Simd(α, n)) :: Simd(Boolean, n):
  ~where Int(_) = α
  prim.icmp_sgt(lhs, rhs)

method (lhs :: Simd(α, n)).$ge(rhs :: Simd(α, n)) :: Simd(Boolean, n):
  ~where UInt(_) || RawPtr || PtrTo(_) = α
  prim.icmp_uge(lhs, rhs)

method (lhs :: Simd(α, n)).$ge(rhs :: Simd(α, n)) :: Simd(Boolean, n):
  ~where Int(_) = α
  prim.icmp_sge(lhs, rhs)

//==============================================================================
method (tst :: Simd(Boolean, n)).select(thn :: α, els :: β) :: γ:
  ~where γ && Simd(_, n) = unify(α, β)
  prim.select(tst, thn :: γ, els :: γ)

//==============================================================================
special_name.def sparse_data
special_name.def sparse_mask

export struct SparseSimd(α :: type, n :: pos_int):
  $sparse_data :: Simd(α, n)
  $sparse_mask :: if ub.checked | Simd(Boolean, n) | Void

coercion (src :: σ) :: δ && SparseSimd(α, n):
  ~when !(α matches SparseSimd(_, _))
  ~where CoercesTo(Simd(α, n)) = σ
  δ{src, #true}

coercion (src :: SparseSimd(UInt(ws), n)) :: δ && SparseSimd(UInt(wd), n):
  ~when ws < wd
  δ{prim.zext(src.$sparse_data, ~to: Simd(UInt(wd), n)),
    src.$sparse_mask}

coercion (src :: SparseSimd(UInt(ws), n)) :: δ && SparseSimd(Int(wd), n):
  ~when ws < wd
  δ{prim.zext(src.$sparse_data, ~to: Simd(Int(wd), n)),
    src.$sparse_mask}

coercion (src :: SparseSimd(Int(ws), n)) :: δ && SparseSimd(Int(wd), n):
  ~when ws < wd
  δ{prim.sext(src.$sparse_data, ~to: Simd(Int(wd), n)),
    src.$sparse_mask}

//==============================================================================
unify(α, SparseSimd(β, n)):
  ~when !(α matches SparseSimd(_, _))
  ~when !(α matches Simd(_, _))
  SparseSimd(unify(α, β), n)

unify(SparseSimd(α, n), SparseSimd(β, n)):
  SparseSimd(unify(α, β), n)

unify(Simd(α, n), SparseSimd(β, n)):
  SparseSimd(unify(α, β), n)

//==============================================================================
method (mask :: Simd(Boolean, n)).sparse_add(lhs :: α, rhs :: β) :: γ:
  ~where γ && SparseSimd(Int(_), n) = unify(α, β)
  let lhs = lhs :: γ
  let rhs = rhs :: γ
  cond
  | ub.allowed:
      γ{prim.add_nsw(lhs.$sparse_data, rhs.$sparse_data),
        #void}
  | ub.suppressed:
      γ{prim.add(lhs.$sparse_data, rhs.$sparse_data),
        #void}
  | ub.checked:
      check_mask_covers(mask, lhs)
      check_mask_covers(mask, rhs)
      let res = prim.sadd_with_overflow(lhs.$sparse_data, rhs.$sparse_data)
      when mask.select(res[1], #false).any() | panic()
      γ{res[0], mask}

method (mask :: Simd(Boolean, n)).sparse_add(lhs :: α, rhs :: β) :: γ:
  ~where γ && SparseSimd(UInt(_), n) = unify(α, β)
  let lhs = lhs :: γ
  let rhs = rhs :: γ
  cond
  | ub.allowed:
      γ{prim.add_nuw(lhs.$sparse_data, rhs.$sparse_data),
        #void}
  | ub.suppressed:
      γ{prim.add(lhs.$sparse_data, rhs.$sparse_data),
        #void}
  | ub.checked:
      check_mask_covers(mask, lhs)
      check_mask_covers(mask, rhs)
      let res = prim.uadd_with_overflow(lhs.$sparse_data, rhs.$sparse_data)
      when mask.select(res[1], #false).any() | panic()
      γ{res[0], mask}

//==============================================================================
method (mask :: Simd(Boolean, n)).sparse_add(
  ptr :: SparseSimd(RawPtr, n),
  offset :: SparseSimd(Int(_), n),
) :: SparseSimd(RawPtr, n):
  when ub.checked | check_mask_covers(mask, ptr)
  let offset = mask.sparse_cast_exact(offset) :: SparseSimd(NativeInt, n)
  let data = cond
  | ub.allowed:
      prim.ptradd ~inbounds (ptr.$sparse_data, offset.$sparse_data)
  | ub.suppressed:
      prim.ptradd(ptr.$sparse_data, offset.$sparse_data)
  | ub.checked:
      let new = prim.ptradd(ptr.$sparse_data, offset.$sparse_data)
      let overflow = offset.$sparse_data > 0 && new ≤ ptr.$sparse_data
      let underflow = offset.$sparse_data < 0 && new ≥ ptr.$sparse_data
      when mask.select(overflow ∨ underflow, #false).any() | panic()
      new
  SparseSimd(RawPtr, n){data, mask}

method (mask :: Simd(Boolean, n)).sparse_add(
  ptr :: SparseSimd(RawPtr, n),
  offset :: SparseSimd(UInt(_), n),
) :: SparseSimd(RawPtr, n):
  when ub.checked | check_mask_covers(mask, ptr)
  let offset = mask.sparse_cast_exact(offset) :: SparseSimd(NativeUInt, n)
  let data = cond
  | ub.allowed:
      prim.ptradd ~inbounds ~nuw (ptr.$sparse_data, offset.$sparse_data)
  | ub.suppressed:
      prim.ptradd(ptr.$sparse_data, offset.$sparse_data)
  | ub.checked:
      let new = prim.ptradd(ptr.$sparse_data, offset.$sparse_data)
      let overflow = new < ptr.$sparse_data
      when mask.select(overflow, #false).any() | panic()
      new
  SparseSimd(RawPtr, n){data, mask}

method (mask :: Simd(Boolean, n)).sparse_add(
  ptr :: SparseSimd(RawPtr, n),
  const offset :: int,
) :: SparseSimd(RawPtr, n):
  when ub.checked | check_mask_covers(mask, ptr)
  cond
  | offset == 0:
      ptr
  | offset > 0:
      mask.sparse_add(ptr, offset :: SparseSimd(NativeUInt, n))
  | offset < 0:
      mask.sparse_add(ptr, offset :: SparseSimd(NativeInt, n))

//==============================================================================
method (mask :: Simd(Boolean, n)).sparse_add(
  ptr :: φ && SparseSimd(PtrTo(α), n),
  offset :: SparseSimd(Int(_), n),
) :: φ:
  let offset = mask.sparse_cast_exact(offset) :: SparseSimd(NativeInt, n)
  let offset = mask.sparse_mul(offset, strideof(α))
  prim.retype(
    mask.sparse_add(
      prim.retype(ptr, ~to: SparseSimd(RawPtr, n)),
      offset),
    ~to: φ)

method (mask :: Simd(Boolean, n)).sparse_add(
  ptr :: φ && SparseSimd(PtrTo(α), n),
  offset :: SparseSimd(UInt(_), n),
) :: φ:
  let offset = mask.sparse_cast_exact(offset) :: SparseSimd(NativeUInt, n)
  let offset = mask.sparse_mul(offset, strideof(α))
  prim.retype(
    mask.sparse_add(
      prim.retype(ptr, ~to: SparseSimd(RawPtr, n)),
      offset),
    ~to: φ)

method (mask :: Simd(Boolean, n)).sparse_add(
  ptr :: φ && SparseSimd(PtrTo(α), n),
  const offset :: int,
) :: φ:
  prim.retype(
    mask.sparse_add(
      prim.retype(ptr, ~to: SparseSimd(RawPtr, n)),
      offset * strideof(α)),
    ~to: φ)

//==============================================================================
method (mask :: Simd(Boolean, n)).sparse_sub(lhs :: α, rhs :: β) :: γ:
  ~where γ && SparseSimd(Int(_), n) = unify(α, β)
  let lhs = lhs :: γ
  let rhs = rhs :: γ
  cond
  | ub.allowed:
      γ{prim.sub_nsw(lhs.$sparse_data, rhs.$sparse_data),
        #void}
  | ub.suppressed:
      γ{prim.sub(lhs.$sparse_data, rhs.$sparse_data),
        #void}
  | ub.checked:
      check_mask_covers(mask, lhs)
      check_mask_covers(mask, rhs)
      let res = prim.ssub_with_overflow(lhs.$sparse_data, rhs.$sparse_data)
      when mask.select(res[1], #false).any() | panic()
      γ{res[0], mask}

method (mask :: Simd(Boolean, n)).sparse_sub(lhs :: α, rhs :: β) :: γ:
  ~where γ && SparseSimd(UInt(_), n) = unify(α, β)
  let lhs = lhs :: γ
  let rhs = rhs :: γ
  cond
  | ub.allowed:
      γ{prim.sub_nuw(lhs.$sparse_data, rhs.$sparse_data),
        #void}
  | ub.suppressed:
      γ{prim.sub(lhs.$sparse_data, rhs.$sparse_data),
        #void}
  | ub.checked:
      check_mask_covers(mask, lhs)
      check_mask_covers(mask, rhs)
      let res = prim.usub_with_overflow(lhs.$sparse_data, rhs.$sparse_data)
      when mask.select(res[1], #false).any() | panic()
      γ{res[0], mask}

//==============================================================================
method (mask :: Simd(Boolean, n)).sparse_sub(
  ptr :: SparseSimd(RawPtr, n),
  amount :: SparseSimd(BinaryInteger, n),
) :: SparseSimd(RawPtr, n):
  let amount = mask.sparse_cast_exact(amount) :: SparseSimd(NativeInt, n)
  mask.sparse_add(ptr, mask.sparse_neg(amount))

method (mask :: Simd(Boolean, n)).sparse_sub(
  ptr :: SparseSimd(RawPtr, n),
  const amount :: int,
) :: SparseSimd(RawPtr, n):
  mask.sparse_add(ptr, -amount)

//==============================================================================
method (mask :: Simd(Boolean, n)).sparse_sub(
  ptr :: φ && SparseSimd(PtrTo(_), n),
  amount :: SparseSimd(BinaryInteger, n),
) :: φ:
  let amount = mask.sparse_cast_exact(amount) :: SparseSimd(NativeInt, n)
  mask.sparse_add(ptr, mask.sparse_neg(amount))

method (mask :: Simd(Boolean, n)).sparse_sub(
  ptr :: φ && SparseSimd(PtrTo(_), n),
  const amount :: int,
) :: SparseSimd(RawPtr, n):
  mask.sparse_add(ptr, -amount)

//==============================================================================
method (mask :: Simd(Boolean, n)).sparse_mul(lhs :: α, rhs :: β) :: γ:
  ~where γ && SparseSimd(Int(_), n) = unify(α, β)
  let lhs = lhs :: γ
  let rhs = rhs :: γ
  cond
  | ub.allowed:
      γ{prim.mul_nsw(lhs.$sparse_data, rhs.$sparse_data),
        #void}
  | ub.suppressed:
      γ{prim.mul(lhs.$sparse_data, rhs.$sparse_data),
        #void}
  | ub.checked:
      check_mask_covers(mask, lhs)
      check_mask_covers(mask, rhs)
      let res = prim.smul_with_overflow(lhs.$sparse_data, rhs.$sparse_data)
      when mask.select(res[1], #false).any() | panic()
      γ{res[0], mask}

method (mask :: Simd(Boolean, n)).sparse_mul(lhs :: α, rhs :: β) :: γ:
  ~where γ && SparseSimd(UInt(_), n) = unify(α, β)
  let lhs = lhs :: γ
  let rhs = rhs :: γ
  cond
  | ub.allowed:
      γ{prim.mul_nuw(lhs.$sparse_data, rhs.$sparse_data),
        #void}
  | ub.suppressed:
      γ{prim.mul(lhs.$sparse_data, rhs.$sparse_data),
        #void}
  | ub.checked:
      check_mask_covers(mask, lhs)
      check_mask_covers(mask, rhs)
      let res = prim.umul_with_overflow(lhs.$sparse_data, rhs.$sparse_data)
      when mask.select(res[1], #false).any() | panic()
      γ{res[0], mask}

//==============================================================================
method (mask :: Simd(Boolean, n)).sparse_div_trunc(lhs :: α, rhs :: β) :: γ:
  ~where γ && SparseSimd(UInt(_), n) = unify(α, β)
  let lhs = lhs :: γ
  let rhs = rhs :: γ
  when ub.checked
  | check_mask_covers(mask, lhs)
    check_mask_covers(mask, rhs)
  cond
  | ub.allowed:
      γ{prim.vp_udiv(lhs.$sparse_data, rhs.$sparse_data, mask),
        #void}
  | ~else:
      let nonzero = rhs.$sparse_data != 0
      cond
      | ub.suppressed:
          γ{prim.vp_udiv(lhs.$sparse_data, rhs.$sparse_data, mask.select(nonzero, #false)),
            #void}
      | ub.checked:
          unless mask.select(nonzero, #true).all() | panic()
          γ{prim.vp_udiv(lhs.$sparse_data, rhs.$sparse_data, mask),
            mask}

method (mask :: Simd(Boolean, n)).sparse_div_floor(lhs, rhs):
  mask.sparse_div_trunc(lhs, rhs)

method (mask :: Simd(Boolean, n)).sparse_rem_trunc(lhs :: α, rhs :: β) :: γ:
  ~where γ && SparseSimd(UInt(_), n) = unify(α, β)
  let lhs = lhs :: γ
  let rhs = rhs :: γ
  when ub.checked
  | check_mask_covers(mask, lhs)
    check_mask_covers(mask, rhs)
  cond
  | ub.allowed:
      γ{prim.vp_urem(lhs.$sparse_data, rhs.$sparse_data, mask),
        #void}
  | ~else:
      let nonzero = rhs.$sparse_data != 0
      cond
      | ub.suppressed:
          γ{prim.vp_urem(lhs.$sparse_data, rhs.$sparse_data, mask.select(nonzero, #false)),
            #void}
      | ub.checked:
          unless mask.select(nonzero, #true).all() | panic()
          γ{prim.vp_urem(lhs.$sparse_data, rhs.$sparse_data, mask),
            mask}

method (mask :: Simd(Boolean, n)).sparse_rem_floor(lhs, rhs):
  mask.sparse_rem_trunc(lhs, rhs)

//==============================================================================
method (mask :: Simd(Boolean, n)).sparse_div_trunc(lhs :: α, rhs :: β) :: γ:
  ~where γ && SparseSimd(Int(w), n) = unify(α, β)
  let lhs = lhs :: γ
  let rhs = rhs :: γ
  when ub.checked
  | check_mask_covers(mask, lhs)
    check_mask_covers(mask, rhs)
  cond
  | ub.allowed:
      γ{prim.vp_sdiv(lhs.$sparse_data, rhs.$sparse_data, mask),
        #void}
  | ~else:
      let safe = sdiv_safe(lhs.$sparse_data, rhs.$sparse_data)
      cond
      | ub.suppressed:
          γ{prim.vp_sdiv(lhs.$sparse_data, rhs.$sparse_data, mask.select(safe, #false)),
            #void}
      | ub.checked:
          unless mask.select(safe, #true).all() | panic()
          γ{prim.vp_sdiv(lhs.$sparse_data, rhs.$sparse_data, mask),
            mask}

method (mask :: Simd(Boolean, n)).sparse_rem_trunc(lhs :: α, rhs :: β) :: γ:
  ~where γ && SparseSimd(Int(w), n) = unify(α, β)
  let lhs = lhs :: γ
  let rhs = rhs :: γ
  when ub.checked
  | check_mask_covers(mask, lhs)
    check_mask_covers(mask, rhs)
  cond
  | ub.allowed:
      γ{prim.vp_srem(lhs.$sparse_data, rhs.$sparse_data, mask),
        #void}
  | ~else:
      let safe = sdiv_safe(lhs.$sparse_data, rhs.$sparse_data)
      cond
      | ub.suppressed:
          γ{prim.vp_srem(lhs.$sparse_data, rhs.$sparse_data, mask.select(safe, #false)),
            #void}
      | ub.checked:
          unless mask.select(safe, #true).all() | panic()
          γ{prim.vp_srem(lhs.$sparse_data, rhs.$sparse_data, mask),
            mask}

fun sdiv_safe(lhs :: Simd(Int(w), n), rhs :: Simd(Int(w), n)):
  (rhs != 0) ∧ ((lhs != Int(w).min_value) ∨ (rhs != -1))

//==============================================================================
method (mask :: Simd(Boolean, n)).sparse_not(smd :: γ && SparseSimd(Bitwise, n)) :: γ:
  when ub.checked | check_mask_covers(mask, smd)
  γ{prim.not(smd.$sparse_data),
    mask}

method (mask :: Simd(Boolean, n)).sparse_and(lhs :: α, rhs :: β) :: γ:
  ~where γ && SparseSimd(Bitwise, n) = unify(α, β)
  let lhs = lhs :: γ
  let rhs = rhs :: γ
  when ub.checked
  | check_mask_covers(mask, lhs)
    check_mask_covers(mask, rhs)
  γ{prim.and(lhs.$sparse_data, rhs.$sparse_data),
    mask}

method (mask :: Simd(Boolean, n)).sparse_or(lhs :: α, rhs :: β) :: γ:
