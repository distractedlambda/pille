method (mask :: Simd(Boolean, n)).sparse_gt(lhs :: α, rhs :: β) :: SparseSimd(Boolean, n):
  ~where γ && SparseSimd(UInt(_) || RawPtr || PtrTo(_), n) = unify(α, β)
  let lhs = lhs :: γ
  let rhs = rhs :: γ
  when ub.checked
  | check_mask_covers(mask, lhs)
    check_mask_covers(mask, rhs)
  SparseSimd(Boolean, n){prim.icmp_ugt(lhs.$sparse_data, rhs.$sparse_data), mask}

method (mask :: Simd(Boolean, n)).sparse_gt(lhs :: α, rhs :: β) :: SparseSimd(Boolean, n):
  ~where γ && SparseSimd(Int(_), n) = unify(α, β)
  let lhs = lhs :: γ
  let rhs = rhs :: γ
  when ub.checked
  | check_mask_covers(mask, lhs)
    check_mask_covers(mask, rhs)
  SparseSimd(Boolean, n){prim.icmp_sgt(lhs.$sparse_data, rhs.$sparse_data), mask}

method (mask :: Simd(Boolean, n)).sparse_ge(lhs :: α, rhs :: β) :: SparseSimd(Boolean, n):
  ~where γ && SparseSimd(UInt(_) || RawPtr || PtrTo(_), n) = unify(α, β)
  let lhs = lhs :: γ
  let rhs = rhs :: γ
  when ub.checked
  | check_mask_covers(mask, lhs)
    check_mask_covers(mask, rhs)
  SparseSimd(Boolean, n){prim.icmp_uge(lhs.$sparse_data, rhs.$sparse_data), mask}

method (mask :: Simd(Boolean, n)).sparse_ge(lhs :: α, rhs :: β) :: SparseSimd(Boolean, n):
  ~where γ && SparseSimd(Int(_), n) = unify(α, β)
  let lhs = lhs :: γ
  let rhs = rhs :: γ
  when ub.checked
  | check_mask_covers(mask, lhs)
    check_mask_covers(mask, rhs)
  SparseSimd(Boolean, n){prim.icmp_sge(lhs.$sparse_data, rhs.$sparse_data), mask}

//==============================================================================
fun check_align
| (ptr :: RawPtr, const align :: alignment) :: Void:
    // FIXME: deduplicate this code
    unless prim.ptrtoint(ptr, ~to: NativeUInt) % align == 0
    | panic()
| (mask :: Simd(Boolean, n), ptrs :: Simd(RawPtr, n), const align :: alignment) :: Void:
    let ptr_ints = prim.ptrtoint(ptrs, ~to: Simd(NativeUInt, n))
    let misalignments = ptr_ints ∧ (align - 1)
    let misaligned = mask.select(misalignments != 0, #false)
    when misaligned.any() | panic()

//==============================================================================
method (mask :: Simd(Boolean, n)).sparse_load(
  ptr :: RawPtr,
  const α :: type,
) :: SparseSimd(α, n):
  mask.sparse_load(ptr, α, alignof(α))

method (mask :: Simd(Boolean, n)).sparse_load(
  ptr :: RawPtr,
  const α :: type,
  const align :: alignment,
) :: SparseSimd(α, n):
  // FIXME: null check, other related stuff
  let data = cond
  | ub.allowed:
      prim.masked_load(ptr, align, mask, prim.poison(Simd(α, n)))
  | ub.suppressed:
      prim.masked_load(ptr, 1, mask, prim.zeroes(Simd(α, n)))
  | ub.checked:
      check_align(ptr, align)
      prim.masked_load(ptr, align, mask, prim.poison(Simd(α, n)))
  SparseSimd(α, n){data, mask}

method (mask :: Simd(Boolean, n)).sparse_load(ptr :: PtrTo(α)) :: SparseSimd(α, n):
  mask.sparse_load(ptr.raw, α)

//==============================================================================
method (mask :: Simd(Boolean, n)).sparse_load(
  ptrs :: SparseSimd(RawPtr, n),
  const α :: type,
) :: SparseSimd(α, n):
  mask.sparse_load(ptrs, α, alignof(α))

method (mask :: Simd(Boolean, n)).sparse_load(
  ptrs :: SparseSimd(RawPtr, n),
  const α :: type,
  const align :: alignment,
) :: SparseSimd(α, n):
  // FIXME: null check, other related stuff
  let data = cond
  | ub.allowed:
      prim.masked_gather(ptrs.$sparse_data, align, mask, prim.poison(Simd(α, n)))
  | ub.suppressed:
      prim.masked_gather(ptrs.$sparse_data, 1, mask, prim.zeroes(Simd(α, n)))
  | ub.checked:
      check_mask_covers(mask, ptrs)
      check_align(mask, ptrs.$sparse_data, align)
      prim.masked_gather(ptrs.$sparse_data, align, mask, prim.poison(Simd(α, n)))
  SparseSimd(α, n){data, mask}

method (mask :: Simd(Boolean, n)).sparse_load(ptrs :: SparseSimd(PtrTo(α), n)) :: SparseSimd(α, n):
  mask.sparse_load(
    prim.retype(ptrs, ~to: SparseSimd(RawPtr, n)),
    α)

//==============================================================================
method (mask :: Simd(Boolean, n)).sparse_store(
  ptr :: RawPtr,
  value :: SparseSimd(α, n),
) :: Void:
  mask.sparse_store(ptr, value, alignof(α))

method (mask :: Simd(Boolean, n)).sparse_store(
  ptr :: RawPtr,
  value :: SparseSimd(_, n),
  const align :: alignment,
) :: Void:
  // FIXME: null check, other related stuff
  cond
  | ub.allowed:
      prim.masked_store(value.$sparse_data, ptr, align, mask)
  | ub.suppressed:
      prim.masked_store(value.$sparse_data, ptr, 1, mask)
  | ub.checked:
      check_mask_covers(mask, value)
      check_align(ptr, align)
      prim.masked_store(value.$sparse_data, ptr, align, mask)

method (mask :: Simd(Boolean, n)).sparse_store(
  ptr :: PtrMut(α),
  value :: SparseSimd(α, n),
) :: Void:
  mask.sparse_store(ptr.raw, value)

//==============================================================================
method (mask :: Simd(Boolean, n)).sparse_store(
  ptrs :: SparseSimd(RawPtr, n),
  value :: SparseSimd(α, n),
) :: Void:
  mask.sparse_store(ptrs, value, alignof(α))

method (mask :: Simd(Boolean, n)).sparse_store(
  ptrs :: SparseSimd(RawPtr, n),
  value :: SparseSimd(_, n),
  const align :: alignment,
) :: Void:
  // FIXME: null check, other related stuff
  cond
  | ub.allowed:
      prim.masked_scatter(value.$sparse_data, ptrs.$sparse_data, align, mask)
  | ub.suppressed:
      prim.masked_scatter(value.$sparse_data, ptrs.$sparse_data, 1, mask)
  | ub.checked:
      check_mask_covers(mask, ptrs)
      check_mask_covers(mask, value)
      check_align(mask, ptrs.$sparse_data, align)
      prim.masked_scatter(value.$sparse_data, ptrs.$sparse_data, align, mask)

method (mask :: Simd(Boolean, n)).sparse_store(
  ptrs :: SparseSimd(PtrMut(α), n),
  value :: SparseSimd(α, n),
) :: Void:
  mask.sparse_store(
    prim.retype(ptrs, ~to: SparseSimd(RawPtr, n)),
    value)

//==============================================================================
struct SparseCastExact(α, n):
  mask :: Simd(Boolean, n)
  src :: SparseSimd(α, n)

method (mask :: Simd(Boolean, n)).sparse_cast_exact(src :: SparseSimd(α, n)):
  when ub.checked | check_mask_covers(mask, src)
  SparseCastExact(α, n){mask, src}

coercion (cast :: SparseCastExact(Int(w1), n)) :: δ && SparseSimd(Int(w2), n):
  cond
  | w1 ≤ w2:
      cast.src
  | ub.allowed:
      δ{prim.trunc_nsw(cast.src.$sparse_data, ~to: Simd(Int(w2), n)),
        #void}
  | ub.suppressed:
      δ{prim.trunc(cast.src.$sparse_data, ~to: Simd(Int(w2), n)),
        #void}
  | ub.checked:
      let src_data = cast.src.$sparse_data
      let in_bounds = (src_data ≥ Int(w2).min_value) ∧ (src_data ≤ Int(w2).max_value)
      unless cast.mask.select(in_bounds, #true).all() | panic()
      δ{prim.trunc_nsw(src_data, ~to: Simd(Int(w2), n)),
        cast.mask}

coercion (cast :: SparseCastExact(UInt(w1), n)) :: δ && SparseSimd(UInt(w2), n):
  cond
  | w1 ≤ w2:
      cast.src
  | ub.allowed:
      δ{prim.trunc_nuw(cast.src.$sparse_data, ~to: Simd(UInt(w2), n)),
        #void}
  | ub.suppressed:
      δ{prim.trunc(cast.src.$sparse_data, ~to: Simd(UInt(w2), n)),
        #void}
  | ub.checked:
      let src_data = cast.src.$sparse_data
      let in_bounds = src_data ≤ UInt(w2).max_value
      unless cast.mask.select(in_bounds, #true).all() | panic()
      δ{prim.trunc_nuw(src_data, ~to: Simd(UInt(w2), n)),
        cast.mask}

// TODO: other casts

//==============================================================================
method (mask :: μ && Simd(Boolean, n)).sparse_refine_mask(test :: SparseSimd(Boolean, n)) :: μ:
  when ub.checked | check_mask_covers(mask, test)
  prim.select(mask, test.$sparse_data, #false :: μ)

//==============================================================================
method (mask :: μ && Simd(Boolean, n)).sparse_select(test :: SparseSimd(Boolean, n), lhs :: α, rhs :: β) :: γ:
  ~where γ && SparseSimd(_, n) = unify(α, β)
  let lhs = lhs :: γ
  let rhs = rhs :: γ
  when ub.checked
  | check_mask_covers(mask, test)
    check_mask_covers(prim.select(mask, test.$sparse_data, #false :: μ), lhs)
    check_mask_covers(prim.select(mask, ¬test.$sparse_data, #false :: μ), rhs)
  γ{prim.select(test.$sparse_data, lhs.$sparse_data, rhs.$sparse_data),
    mask}

//==============================================================================
method (mask :: Simd(Boolean, n)).sparse_assign(inout dst :: δ && SparseSimd(_, n), src :: CoercesTo(δ)) :: Void:
  let src = src :: δ
  when ub.checked | check_mask_covers(mask, src)
  dst := δ{prim.select(mask, src.$sparse_data, dst.$sparse_data),
           if ub.checked | mask ∨ dst.$sparse_mask | #void}

//==============================================================================
fun check_mask_covers(mask :: Simd(Boolean, n), smd :: SparseSimd(_, n)) :: Void:
  unless (mask ∧ smd.$sparse_mask) === mask
  | panic()
