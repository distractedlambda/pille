    check_mask_covers(mask, rhs)
  SparseSimd(Boolean, n){prim.icmp_ult(lhs.$sparse_data, rhs.$sparse_data), mask}

method (mask :: Simd(Boolean, n)).sparse_lt(lhs :: α, rhs :: β) :: SparseSimd(Boolean, n):
  ~where γ && SparseSimd(Int(_), n) = unify(α, β)
