  let rhs = rhs :: γ
  when ub.checked
  | check_mask_covers(mask, lhs)
    check_mask_covers(mask, rhs)
  γ{prim.or(lhs.$sparse_data, rhs.$sparse_data),
    mask}

method (mask :: Simd(Boolean, n)).sparse_xor(lhs :: α, rhs :: β) :: γ:
